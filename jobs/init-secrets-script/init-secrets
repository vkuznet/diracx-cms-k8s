#!/usr/bin/env bash
# init-secrets – Bootstrap DiracX secrets in the target namespace.
#
# Originally generated from the diracx Helm chart's init-secrets job template.
# All Helm template variables have been resolved to concrete values for the
# CMS/external-cluster deployment.
#
# What this script does:
#   1. Generates diracx-dynamic-secrets  (auth state signing key)
#   2. Generates / patches mysql-secret  (root, replication, app passwords)
#   3. Generates diracx-sql-connection-urls  (per-DB DSNs for the app user)
#   4. Generates diracx-sql-root-connection-urls  (per-DB DSNs for root)
#   5. Generates diracx-os-connection-urls  (OpenSearch DSN per index)
#   6. Generates diracx-os-root-connection-urls  (OpenSearch root DSN per index)
#
# All secrets are idempotent: existing secrets are never overwritten, but any
# missing keys inside an existing secret are patched in.
#
# Configuration – edit the block below before running.
# -------------------------------------------------------
NAMESPACE="${NAMESPACE:-default}"
RELEASE="${RELEASE:-diracx-cms}"

# MySQL service hostname (StatefulSet headless DNS name)
MYSQL_HOST="${MYSQL_HOST:-${RELEASE}-mysql:3306}"
# MySQL application username (the non-root account DiracX uses at runtime)
MYSQL_APP_USER="${MYSQL_APP_USER:-sqldiracx}"
# Name of the k8s Secret that holds mysql-root-password / mysql-password / etc.
MYSQL_SECRET_NAME="${MYSQL_SECRET_NAME:-mysql-secret}"

# OpenSearch service hostname
OS_HOST="${OS_HOST:-opensearch-cluster-master:9200}"
# OpenSearch credentials (same for app and root in the bundled deployment)
OS_USER="${OS_USER:-admin}"
OS_PASSWORD="${OS_PASSWORD:-admin}"
OS_ROOT_USER="${OS_ROOT_USER:-admin}"
OS_ROOT_PASSWORD="${OS_ROOT_PASSWORD:-admin}"

# SQL databases to create secrets for (space-separated, case-sensitive)
# Use arrays so iteration works regardless of IFS
SQL_DBS=(AuthDB JobDB JobLoggingDB PilotAgentsDB SandboxMetadataDB TaskQueueDB)

# OpenSearch index databases to create secrets for
OS_DBS=(JobParametersDB PilotLogsDB)
# -------------------------------------------------------

set -euo pipefail
# NOTE: IFS is intentionally left as default (space/tab/newline).
# The original Helm template used IFS=$'\n\t' which causes a space-separated
# string like "AuthDB JobDB ..." to be treated as a single token.
# We avoid that entirely by using bash arrays.

pushd "$(mktemp -d)"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# gen_random <charset> <length>
function gen_random() {
  head -c 4096 /dev/urandom | LC_CTYPE=C tr -cd "$1" | head -c "$2"
}

# generate_secret_if_needed <secret-name> [--from-literal=key=value ...]
#
# Creates the secret if it does not exist.  If it already exists, iterates
# over every --from-literal argument and patches in any key that is missing.
function generate_secret_if_needed() {
  local secret_name=$1
  local secret_args=("${@:2}")

  if ! kubectl --namespace="$NAMESPACE" get secret "$secret_name" > /dev/null 2>&1; then
    echo "Creating secret \"${secret_name}\"..."
    kubectl --namespace="$NAMESPACE" create secret generic "$secret_name" "${secret_args[@]}"
  else
    echo "Secret \"${secret_name}\" already exists – checking for missing keys..."

    for arg in "${secret_args[@]}"; do
      # Only process --from-literal= arguments
      local from
      from=$(echo -n "${arg}" | cut -d '=' -f1)
      [[ "${from}" != *"literal"* ]] && continue

      local key
      key=$(echo -n "${arg}" | cut -d '=' -f2)
      local desiredValue
      desiredValue=$(echo -n "${arg}" | cut -d '=' -f3-)

      local flags=(
        "--namespace=$NAMESPACE"
        "--allow-missing-template-keys=false"
      )

      if ! kubectl "${flags[@]}" get secret "$secret_name" \
           -o jsonpath="{.data.${key}}" > /dev/null 2>&1; then
        echo "  Key \"${key}\" missing in \"${secret_name}\" – patching..."
        local encoded=""
        if [[ -n "${desiredValue}" ]]; then
          encoded=$(echo -n "${desiredValue}" | base64 -w 0)
        fi
        kubectl --namespace="$NAMESPACE" patch secret "${secret_name}" \
          -p "{\"data\":{\"${key}\":\"${encoded}\"}}"
      else
        echo "  Key \"${key}\" already present – skipping."
      fi
    done
  fi
}

# ---------------------------------------------------------------------------
# 1. DiracX auth-state signing key
# ---------------------------------------------------------------------------
echo "==> diracx-dynamic-secrets"
generate_secret_if_needed diracx-dynamic-secrets \
  --from-literal=DIRACX_SERVICE_AUTH_STATE_KEY="$(head -c 32 /dev/urandom | base64)"

# ---------------------------------------------------------------------------
# 2. MySQL passwords
# ---------------------------------------------------------------------------
echo "==> ${MYSQL_SECRET_NAME}"
generate_secret_if_needed "${MYSQL_SECRET_NAME}" \
  --from-literal=mysql-root-password="$(gen_random 'a-zA-Z0-9' 32)" \
  --from-literal=mysql-replication-password="$(gen_random 'a-zA-Z0-9' 32)" \
  --from-literal=mysql-password="$(gen_random 'a-zA-Z0-9' 32)"

# Read back the (possibly just-created) passwords for use in DSN secrets
MYSQL_APP_PASSWORD=$(kubectl get secret "${MYSQL_SECRET_NAME}" \
  --namespace="$NAMESPACE" -o jsonpath="{.data.mysql-password}" | base64 -d)
MYSQL_ROOT_PASSWORD=$(kubectl get secret "${MYSQL_SECRET_NAME}" \
  --namespace="$NAMESPACE" -o jsonpath="{.data.mysql-root-password}" | base64 -d)

# ---------------------------------------------------------------------------
# 3 & 4. Per-database SQL connection URL secrets
# ---------------------------------------------------------------------------
echo "==> diracx-sql-connection-urls / diracx-sql-root-connection-urls"
for DB in "${SQL_DBS[@]}"; do
  DB_UPPER=$(echo "${DB}" | tr '[:lower:]' '[:upper:]')

  generate_secret_if_needed diracx-sql-connection-urls \
    --from-literal="DIRACX_DB_URL_${DB_UPPER}=mysql+aiomysql://${MYSQL_APP_USER}:${MYSQL_APP_PASSWORD}@${MYSQL_HOST}/${DB}"

  generate_secret_if_needed diracx-sql-root-connection-urls \
    --from-literal="DIRACX_DB_URL_${DB_UPPER}=mysql+aiomysql://root:${MYSQL_ROOT_PASSWORD}@${MYSQL_HOST}/${DB}"
done

# ---------------------------------------------------------------------------
# 5 & 6. Per-index OpenSearch connection URL secrets
# ---------------------------------------------------------------------------
echo "==> diracx-os-connection-urls / diracx-os-root-connection-urls"
for OSDB in "${OS_DBS[@]}"; do
  OSDB_UPPER=$(echo "${OSDB}" | tr '[:lower:]' '[:upper:]')

  generate_secret_if_needed diracx-os-connection-urls \
    --from-literal="DIRACX_OS_DB_${OSDB_UPPER}={\"hosts\": \"${OS_USER}:${OS_PASSWORD}@${OS_HOST}\", \"use_ssl\": true, \"verify_certs\": false}"

  generate_secret_if_needed diracx-os-root-connection-urls \
    --from-literal="DIRACX_OS_DB_${OSDB_UPPER}={\"hosts\": \"${OS_ROOT_USER}:${OS_ROOT_PASSWORD}@${OS_HOST}\", \"use_ssl\": true, \"verify_certs\": false}"
done

echo "==> Done."
popd
